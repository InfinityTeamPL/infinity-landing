# Environment Variables - COPY THIS FILE TO .env.local

# --- OpenAI (chat widget) ---
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here
# Model: gpt-4o-mini is most cost-effective, alternatives: gpt-4o, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# --- Resend (waitlist signups) ---
# Get your API key from: https://resend.com/api-keys
# Required for /api/waitlist to actually deliver signup notifications.
RESEND_API_KEY=re_your_resend_api_key_here
# Where waitlist notifications are sent. Defaults to contact@infinityteam.io.
WAITLIST_TO=contact@infinityteam.io
# From address. Must be a verified domain in Resend, or use the default sandbox.
# Example after domain verification: "Infinity Waitlist <waitlist@infinityteam.io>"
WAITLIST_FROM=Infinity Waitlist <onboarding@resend.dev>
